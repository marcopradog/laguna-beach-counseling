<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{% if metaTitle %}{{ metaTitle }}{% elif title %}{{ title }} | {{ site.name }}{% else %}{{ site.name }}{% endif %}</title>
    <meta name="description" content="{{ description or site.defaultDescription }}" />
    <meta name="theme-color" content="{{ site.themeColor }}" />
    {% if robots %}<meta name="robots" content="{{ robots }}" />{% elif noindex %}<meta name="robots" content="noindex" />{% endif %}
    <link rel="canonical" href="{{ site.url }}{{ page.url }}" />

    {# Fonts: DM Serif Display (display) and Manrope (UI), display=swap. #}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Manrope:wght@300;400;500;600;700&display=swap"
    />

    {# Versioned by content hash (src/_data/cssVersion.js) so the immutable
       one-year cache on /css/* can never serve stale styles after a deploy. #}
    <link rel="stylesheet" href="/css/main.css?v={{ cssVersion }}" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    {% include "components/header.njk" %}

    <main id="main">
      {{ content | safe }}
    </main>

    {% include "components/footer.njk" %}

    <script src="/js/menu.js" defer></script>
  </body>
</html>
