---
layout: layouts/base.njk
---
{#
  practical-led: page template for logistics-forward topics (neurodiversity,
  addiction-recovery, most therapy-audience pages, section landings, fees, faq,
  couples-intensive, telehealth). See COMPONENT_COVERAGE.md for the mapping.

  Keys (all optional unless marked required; absent keys render nothing):

    crumbs      [{label, url?}]
    hero        { eyebrow, title (required), titleEmphasis?, lead?, variant?,
                  image?, trust?, gold?, ctaLabel?, ctaHref?, secondaryCta? }
    lead        string | string[]
    steps       { eyebrow, title, titleEmphasis?, lead?, steps[{title, body}] }
                "what to expect" as the numbered timeline
    trust       { lead, leadEmphasis?, items[{icon, title, text}], columns?, tone? }
                the inline trust band; defaults to the navy ground
    points      { eyebrow, title, columns?, cards[], cardStyle?, tone? }
    rates       { caption, rows[{service, rate, note?}], footnote? }
                confirmed figures only, never invented (makes /fees fit)
    crossSell   { eyebrow, title, titleEmphasis?, body, href, label, image?,
                  reverse?, imageWeight?, anchorLine?, pullQuote?, tone? }
    next        { eyebrow, title, titleEmphasis?, columns?, cards[], tone? }
    faq         { eyebrow, title, items[{q,a}], variant? }  also emits faqSchema
    support     true renders the crisis support-resources block
    cta         { title, titleEmphasis?, text?, note?, watermark?, tagline?,
                  href?, label?, variant? }
    service     { name, serviceType, description, areaServed? }

  The page BODY renders at the content slot after points/rates and before the
  cross-sell, for page-specific extra sections (for example the couples
  premarital section or the teens mother-and-daughter block).

  Enforced here, not by convention: the CTA band is always tone sand (the navy
  band must never sit directly above the navy footer), the hero renders the
  page's only h1, the hero CTA is navy unless the page opts into hero.gold.
  Facts come from front matter and site data, never hardcoded. No em dashes.
#}
{% import "components/ui.njk" as ui %}
{% import "components/sections.njk" as s %}

{% if crumbs %}{{ s.breadcrumbs(crumbs) }}{% endif %}

{{ s.hero({
  eyebrow: hero.eyebrow,
  title: hero.title,
  titleEmphasis: hero.titleEmphasis,
  lead: hero.lead,
  variant: hero.variant,
  image: hero.image,
  trust: hero.trust,
  cta: { href: hero.ctaHref or site.booking.getStartedPath, label: hero.ctaLabel or site.booking.navLabel, gold: hero.gold },
  secondaryCta: hero.secondaryCta
}) }}

{% if lead %}{{ s.lead({ text: lead }) }}{% endif %}

{% if steps %}
  {{ s.steps({ eyebrow: steps.eyebrow, title: steps.title, titleEmphasis: steps.titleEmphasis, lead: steps.lead, steps: steps.steps }) }}
{% endif %}

{% if trust %}
  {{ s.featureRow({
    variant: "inline",
    tone: trust.tone or "navy",
    lead: trust.lead,
    leadEmphasis: trust.leadEmphasis,
    columns: trust.columns,
    items: trust.items
  }) }}
{% endif %}

{% if points %}
  {{ s.pointCards({ eyebrow: points.eyebrow, title: points.title, columns: points.columns, cards: points.cards, cardStyle: points.cardStyle, tone: points.tone }) }}
{% endif %}

{% if rates %}
  {{ s.rateTable({ caption: rates.caption, rows: rates.rows, footnote: rates.footnote }) }}
{% endif %}

{# Content slot: page-specific sections composed from the library land here. #}
{{ content | safe }}

{% if crossSell %}
  {{ s.promoCallout({
    eyebrow: crossSell.eyebrow,
    title: crossSell.title,
    titleEmphasis: crossSell.titleEmphasis,
    body: crossSell.body,
    cta: { href: crossSell.href, label: crossSell.label },
    image: crossSell.image,
    reverse: crossSell.reverse,
    imageWeight: crossSell.imageWeight,
    anchorLine: crossSell.anchorLine,
    pullQuote: crossSell.pullQuote,
    tone: crossSell.tone
  }) }}
{% endif %}

{% if next %}
  {{ s.pointCards({ eyebrow: next.eyebrow, title: next.title, columns: next.columns or 2, cards: next.cards, tone: next.tone or "sand" }) }}
{% endif %}

{% if faq %}{{ s.faq({ eyebrow: faq.eyebrow, title: faq.title, items: faq.items, variant: faq.variant }) }}{% endif %}

{% if support %}
  {% call ui.section({ tone: "paper", width: "narrow" }) %}
    {% set onFooter = false %}
    {% include "components/support-resources.njk" %}
  {% endcall %}
{% endif %}

{{ s.ctaBand({
  variant: cta.variant or "center",
  tone: "sand",
  watermark: cta.watermark,
  title: cta.title,
  titleEmphasis: cta.titleEmphasis,
  text: cta.text,
  note: cta.note,
  tagline: cta.tagline,
  cta: { href: cta.href or site.booking.getStartedPath, label: cta.label or site.booking.navLabel }
}) }}

{% if service %}
  {{ s.serviceSchema({
    name: service.name,
    serviceType: service.serviceType,
    description: service.description,
    url: page.url,
    business: { url: site.url, name: site.name, telephone: site.nap.telephone },
    areaServed: service.areaServed
  }) }}
{% endif %}
{% if crumbs %}{{ s.breadcrumbSchema(crumbs, site.url) }}{% endif %}
{% if faq %}{{ s.faqSchema(faq.items) }}{% endif %}
