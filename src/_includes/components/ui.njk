{# Foundation macros for the component library. Pure functions of their params:
   they never read global data, so pages pass facts in from site.json and the
   partials stay reusable. Import with: {% import "components/ui.njk" as ui %}.
   No em dashes anywhere. Icons are inline SVG only, no emojis, no CDN. #}

{# Forward arrow, shared by buttons and links. Decorative, so aria-hidden. #}
{% macro arrow() %}<svg class="btn__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="18" y2="12" /><polyline points="12 6 18 12 12 18" /></svg>{% endmacro %}

{# button(opts): { href, label, variant: primary | ghost | text, arrow, ariaLabel, class }
   primary = navy pill, ghost = outline pill, text = inline text link. Never gold;
   gold is reserved for the CTA band. #}
{% macro button(opts) %}
  {% set variant = opts.variant or "primary" %}
  {% set cls = "btn-text" if variant == "text" else "btn btn-" + variant %}
  <a class="{{ cls }}{% if opts.class %} {{ opts.class }}{% endif %}" href="{{ opts.href }}"{% if opts.ariaLabel %} aria-label="{{ opts.ariaLabel }}"{% endif %}>{{ opts.label }}{% if opts.arrow %}{{ arrow() }}{% endif %}</a>
{% endmacro %}

{# eyebrow(opts): { text } or a bare string. The signature device, a small teal
   wave mark then an uppercase word, marking the start of a section. Teal, not
   gold, so many eyebrows never breach the one-gold-per-viewport budget. The wave
   is hidden on mobile (text-only) via CSS; markup stays the same. #}
{% macro eyebrow(opts) %}
  {% set text = opts.text or opts %}
  <p class="eyebrow"><span class="eyebrow__rule" aria-hidden="true"></span>{{ text }}</p>
{% endmacro %}

{# section(opts): wrapper used as {% call ui.section({tone,width,id}) %}...{% endcall %}
   tone: paper | sand | seafoam | navy. width: default | narrow. Gives every
   section the same vertical rhythm and reading measure. #}
{% macro section(opts) %}
  {% set tone = opts.tone or "paper" %}
  {% set width = opts.width or "default" %}
  <section class="section section--{{ tone }}{% if opts.class %} {{ opts.class }}{% endif %}"{% if opts.id %} id="{{ opts.id }}"{% endif %}>
    <div class="container section__inner section__inner--{{ width }}">
      {{ caller() }}
    </div>
  </section>
{% endmacro %}

{# icon(name): inline SVG from a small, intentional coastal set. Decorative by
   default (aria-hidden); the adjacent heading carries the meaning. #}
{% macro icon(name) %}
<svg class="icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
{%- if name == "wave" -%}
  <path d="M2 9.5c1.7 0 1.7 1.6 3.3 1.6S7 9.5 8.7 9.5s1.6 1.6 3.3 1.6 1.6-1.6 3.3-1.6 1.6 1.6 3.3 1.6S22 9.5 22 9.5" /><path d="M2 14.5c1.7 0 1.7 1.6 3.3 1.6s1.7-1.6 3.4-1.6 1.6 1.6 3.3 1.6 1.6-1.6 3.3-1.6 1.6 1.6 3.3 1.6 1.4-1.6 3.1-1.6" />
{%- elif name == "sun" -%}
  <circle cx="12" cy="12" r="4" /><line x1="12" y1="2" x2="12" y2="4.5" /><line x1="12" y1="19.5" x2="12" y2="22" /><line x1="2" y1="12" x2="4.5" y2="12" /><line x1="19.5" y1="12" x2="22" y2="12" /><line x1="4.9" y1="4.9" x2="6.7" y2="6.7" /><line x1="17.3" y1="17.3" x2="19.1" y2="19.1" /><line x1="19.1" y1="4.9" x2="17.3" y2="6.7" /><line x1="6.7" y1="17.3" x2="4.9" y2="19.1" />
{%- elif name == "compass" -%}
  <circle cx="12" cy="12" r="9" /><polygon points="12 7 14.2 12 12 17 9.8 12" />
{%- elif name == "anchor" -%}
  <circle cx="12" cy="5" r="2" /><line x1="12" y1="7" x2="12" y2="20" /><path d="M5 12a7 7 0 0 0 14 0" /><line x1="4" y1="12" x2="7.5" y2="12" /><line x1="16.5" y1="12" x2="20" y2="12" />
{%- elif name == "shell" -%}
  <path d="M12 3a9 8 0 0 0-9 8c0 5.2 4 10 9 10s9-4.8 9-10a9 8 0 0 0-9-8Z" /><path d="M12 3v18" /><path d="M12 21c-3-4-5-8.5-6-13.5" /><path d="M12 21c3-4 5-8.5 6-13.5" />
{%- elif name == "chat" -%}
  <path d="M4.5 5h15a1 1 0 0 1 1 1v9a1 1 0 0 1-1 1H10l-4.5 3.2V16H4.5a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1Z" />
{%- elif name == "clock" -%}
  <circle cx="12" cy="12" r="9" /><path d="M12 7v5.2l3.2 2" />
{%- elif name == "shield" -%}
  <path d="M12 3l7 2.8v5c0 5-3 8.1-7 10-4-1.9-7-5-7-10v-5Z" /><path d="M9 12l2 2 4-4" />
{%- elif name == "heart" -%}
  <path d="M12 20s-7-4.6-7-10a3.9 3.9 0 0 1 7-2.5A3.9 3.9 0 0 1 19 10c0 5.4-7 10-7 10Z" />
{%- elif name == "phone" -%}
  <path d="M6.5 4h3l1.4 3.6-2 1.4a12 12 0 0 0 5.6 5.6l1.4-2 3.6 1.4v3a1.5 1.5 0 0 1-1.6 1.5A15.5 15.5 0 0 1 5 6.6 1.5 1.5 0 0 1 6.5 4Z" />
{%- else -%}
  <circle cx="12" cy="12" r="9" />
{%- endif -%}
</svg>
{% endmacro %}
