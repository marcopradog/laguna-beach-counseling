{# Sticky site header with desktop nav and an accessible mobile menu.
   Logo is a text lockup until the tower mark from the bunny.net CDN is wired. #}
<header class="site-header">
  <div class="container site-header__inner">
    <a class="site-header__brand" href="/">{{ site.name }}</a>

    <nav class="site-nav" aria-label="Primary">
      <ul class="site-nav__list">
        {% for item in site.nav %}
          <li><a class="site-nav__link" href="{{ item.url }}">{{ item.label }}</a></li>
        {% endfor %}
      </ul>
    </nav>

    <div class="site-header__actions">
      <a class="btn btn-accent" href="{{ site.booking.getStartedPath }}">{{ site.booking.callLabel }}</a>
      <button
        class="menu-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="mobile-nav"
        data-menu-toggle
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
        <span>Menu</span>
      </button>
    </div>
  </div>

  <nav class="mobile-nav" id="mobile-nav" aria-label="Mobile" hidden>
    <div class="container">
      <ul class="mobile-nav__list">
        {% for item in site.nav %}
          <li><a href="{{ item.url }}">{{ item.label }}</a></li>
        {% endfor %}
        <li><a href="{{ site.booking.getStartedPath }}">{{ site.booking.callLabel }}</a></li>
      </ul>
    </div>
  </nav>
</header>
