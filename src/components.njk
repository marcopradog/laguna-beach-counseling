---
layout: layouts/base.njk
title: Component library
permalink: /components/
robots: "noindex, nofollow"
eleventyExcludeFromCollections: true
sitemapExclude: true
---
{# Internal, unlisted showcase. It imports the SAME partials the pages use, so it
   is a live mirror of the library, not a copy. Kept out of Google: noindex and
   nofollow above, excluded from collections and the sitemap, absent from nav,
   and disallowed in robots.txt. Demo copy is drawn from real briefs and the
   canonical pull-quotes so it reads on-brand. #}
{% import "components/ui.njk" as ui %}
{% import "components/sections.njk" as s %}

<section class="section section--navy showcase-head">
  <div class="container">
    <p class="eyebrow"><span class="eyebrow__rule"></span>Internal reference</p>
    <h1>Component library</h1>
    <p class="showcase-head__lead">The page-body vocabulary for Laguna Beach Counseling. Every block below is the real partial from <code>components/ui.njk</code> and <code>components/sections.njk</code>, rendered live. Compose pages from these; do not build sections one-off. This page is not indexed, not in the sitemap, and not in the nav.</p>
  </div>
</section>

{# ---- Foundation -------------------------------------------------------- #}
<div class="showcase__item">
  <div class="container showcase__meta">
    <p class="showcase__label">button</p>
    <p class="showcase__note">params: href, label, variant (primary | ghost | text), arrow, ariaLabel</p>
  </div>
  <div class="container showcase__row">
    {{ ui.button({ href: site.booking.getStartedPath, label: "Book a free call", variant: "primary", arrow: true }) }}
    {{ ui.button({ href: "/about/our-team", label: "Meet the team", variant: "ghost" }) }}
    {{ ui.button({ href: "/beach-therapy", label: "Read Kay's story", variant: "text", arrow: true }) }}
  </div>
</div>

<div class="showcase__item">
  <div class="container showcase__meta">
    <p class="showcase__label">eyebrow and icons</p>
    <p class="showcase__note">eyebrow(text); icon(name): wave, sun, compass, anchor, shell, chat, clock, shield, heart, phone</p>
  </div>
  <div class="container">
    {{ ui.eyebrow("Signature service") }}
  </div>
  {% set iconNames = ["wave", "sun", "compass", "anchor", "shell", "chat", "clock", "shield", "heart", "phone"] %}
  <div class="container showcase__icons">
    {% for n in iconNames %}
      <span class="showcase__icon">{{ ui.icon(n) }}<span>{{ n }}</span></span>
    {% endfor %}
  </div>
</div>

<div class="showcase__item">
  <div class="container showcase__meta">
    <p class="showcase__label">section wrapper</p>
    <p class="showcase__note">call ui.section({ tone: paper | sand | seafoam | navy, width: default | narrow, id }); wraps arbitrary content</p>
  </div>
  {% call ui.section({ tone: "seafoam", width: "narrow" }) %}
    <p class="lead__p">The section wrapper gives any content the same vertical rhythm, background tone, and reading measure as the named components. This one is sea-foam and narrow.</p>
  {% endcall %}
</div>

{# ---- Textures ---------------------------------------------------------- #}
<div class="showcase__item">
  <div class="container showcase__meta">
    <p class="showcase__label">textures</p>
    <p class="showcase__note">utility classes from base/textures.css: .t-grain (warm paper grain), .t-foam (sea-foam wash), .t-pill (gold dot pattern). The same grain sits on sand sections at 4.5% multiply.</p>
  </div>
  <div class="container showcase__textures">
    <div class="showcase__tex t-grain"><span>t-grain</span></div>
    <div class="showcase__tex t-foam"><span>t-foam</span></div>
    <div class="showcase__tex t-pill"><span>t-pill</span></div>
  </div>
</div>

