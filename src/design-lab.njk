{#
  DESIGN LAB. A temporary working exploration doc, not the finished library.
  Design iteration only. Do NOT ship, do NOT extract into ui.njk/sections.njk,
  do NOT commit.

  Shows the kept design direction(s) per device after review, plus later devices.
  Copy is the real anxiety copy where it exists, reused across variations. Gold is
  used only on the CTA buttons, the SEO digits, and the pullquote left rule / tick;
  every other accent is teal or sea-foam.

  Isolation matches the freeform experiment: noindex/nofollow, out of sitemap,
  out of collections, not in nav. Every class is ff- or ff-guide- prefixed.
  To remove: delete this file, src/css/pages/design-lab.css, and the import line
  in src/css/main.css.
#}

{% set icoArrow %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14" /><path d="M12 5l7 7-7 7" /></svg>{% endset %}
{% set icoArrowThin %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14" /><path d="M12 5l7 7-7 7" /></svg>{% endset %}
{% set icoChevron %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 6 15 12 9 18" /></svg>{% endset %}
{% set icoCamera %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z" /><circle cx="12" cy="13" r="4" /></svg>{% endset %}
{% set icoWave %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 11c1.6 0 1.6-1.6 3.2-1.6S6.8 11 8.4 11s1.6-1.6 3.2-1.6S13.2 11 14.8 11s1.6-1.6 3.2-1.6S19.6 11 22 11" /><path d="M2 16.5c1.6 0 1.6-1.6 3.2-1.6s1.6 1.6 3.2 1.6 1.6-1.6 3.2-1.6 1.6 1.6 3.2 1.6 1.6-1.6 3.2-1.6 1.6 1.6 4 1.6" /></svg>{% endset %}
{% set icoHeart %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20s-7-4.6-7-10a3.9 3.9 0 0 1 7-2.5A3.9 3.9 0 0 1 19 10c0 5.4-7 10-7 10Z" /></svg>{% endset %}
{% set icoCompass %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9" /><polygon points="12 7 14.2 12 12 17 9.8 12" /></svg>{% endset %}
{% set icoShield %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3l7 2.8v5c0 5-3 8.1-7 10-4-1.9-7-5-7-10v-5Z" /></svg>{% endset %}
{% set icoChat %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4.5 5h15a1 1 0 0 1 1 1v9a1 1 0 0 1-1 1H10l-4.5 3.2V16H4.5a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1Z" /></svg>{% endset %}
{% set icoClock %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9" /><path d="M12 7v5.2l3.2 2" /></svg>{% endset %}
{% set icoCheck %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5" /></svg>{% endset %}
{% set icoPlus %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14" /></svg>{% endset %}
{% set icoPlay %}<svg viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true"><path d="M8 5.5v13l11-6.5z" /></svg>{% endset %}

{% macro photo(lbl, desc, path, wide=false) %}
<div class="ff-photo-needed{% if wide %} ff-photo-needed--wide{% endif %}">
  <span class="ff-ph-icon">{{ icoCamera | safe }}</span>
  <p class="ff-ph-lbl">{{ lbl }}</p>
  <p class="ff-ph-desc">{{ desc }}</p>
  <p class="ff-ph-path">{{ path }}</p>
</div>
{% endmacro %}

